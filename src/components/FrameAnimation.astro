---
const TOTAL_FRAMES = 420;
const FRAME_BASE = "/frames/Shot_2_Webp/Shots.";
const FRAME_SUFFIX = "_result.webp";

const TEXT_SECTIONS = [
    {
        from: 97,
        label: "01",
        heading: "Meet Ultra Buds Pro",
        body: "This is not just sound. This is a revolution in audio technology, crafted for those who demand the best.",
    },
    {
        from: 150,
        label: "02",
        heading: "Sleek Design",
        body: "Clean lines meet bold aesthetics. Makes a statement, not just sound.",
    },
    {
        from: 240,
        label: "03",
        heading: "Dual Stereo Drivers",
        body: "Sound so real, you can feel it. Hear every note, every beat, with stunning clarity and depth.",
    },
    {
        from: 380,
        label: "04",
        heading: "Experience it now.",
        body: "To learn more, check out our app and discover the future of sound with Ultra Buds Pro.",
    },
];
---

<section
    id="animation-section"
    data-frames={TOTAL_FRAMES}
    data-base={FRAME_BASE}
    data-suffix={FRAME_SUFFIX}
>
    <!-- Left: text panel -->
    <div id="anim-text-panel">
        {
            TEXT_SECTIONS.map((s, i) => (
                <div class="anim-slide" data-index={i} data-from={s.from}>
                    <span class="anim-label">{s.label}</span>
                    <h2 class="anim-heading">{s.heading}</h2>
                    <p class="anim-body">{s.body}</p>
                </div>
            ))
        }
    </div>

    <!-- Right: canvas panel -->
    <div id="anim-canvas-panel">
        <canvas id="animation-canvas"></canvas>
        <div id="animation-loader">
            <div id="loader-bar-wrap"><div id="loader-bar"></div></div>
            <p id="loader-text">Loading…</p>
        </div>
    </div>
</section>

<style>
    #animation-section {
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
        background: #000;
        overflow: hidden;
        position: relative;
    }

    /* ── Text panel ── */
    #anim-text-panel {
        height: 35%;
        width: 100%;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: stretch;
    }

    .anim-slide {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 0 5vw;
        will-change: transform;
    }

    .anim-label {
        display: block;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        margin-bottom: 1.25rem;
    }

    .anim-heading {
        font-size: clamp(2rem, 3vw, 4rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.08;
        color: #fff;
        margin-bottom: 1rem;
    }

    .anim-body {
        font-size: clamp(0.9rem, 1.1vw, 1.1rem);
        color: rgba(255, 255, 255, 0.55);
        line-height: 1.65;
        max-width: 52ch;
    }

    /* ── Canvas panel ── */
    #anim-canvas-panel {
        flex: 1;
        width: 100%;
        position: relative;
        background: #000;
    }

    #animation-canvas {
        display: block;
        width: 100%;
        height: 100%;
    }

    #animation-loader {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        background: #000;
        transition: opacity 0.4s ease;
    }

    #loader-bar-wrap {
        width: 160px;
        height: 2px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 2px;
        overflow: hidden;
    }

    #loader-bar {
        height: 100%;
        width: 0%;
        background: #fff;
        border-radius: 2px;
        transition: width 0.1s linear;
    }

    #loader-text {
        color: rgba(255, 255, 255, 0.35);
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 0;
    }

    /* ── Mobile: hide animation, show text stacked ── */
    @media (max-width: 767px) {
        #animation-section {
            height: auto;
        }

        #anim-canvas-panel {
            display: none;
        }

        #anim-text-panel {
            height: auto;
            position: static;
            overflow: visible;
            display: block;
        }

        .anim-slide {
            position: static;
            padding: 4rem 2rem;
            transform: none !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // ── Sliding-window config ──
    const WINDOW_AHEAD = 20;
    const WINDOW_BEHIND = 5;
    const CRITICAL = 25;
    const FETCH_CONCURRENCY = 8;
    // Frame index at which each text section starts — mirrors TEXT_SECTIONS[].from
    const SECTION_STARTS = Array.from(
        document.querySelectorAll<HTMLElement>(".anim-slide"),
    ).map((el) => Number(el.dataset.from));

    // ── Read config ──
    const section = document.getElementById("animation-section")!;
    const TOTAL_FRAMES = Number(section.dataset.frames);
    const FRAME_BASE = section.dataset.base!;
    const FRAME_SUFFIX = section.dataset.suffix!;

    const slides = Array.from(
        document.querySelectorAll<HTMLElement>(".anim-slide"),
    );
    const NUM_SECTIONS = slides.length;

    // ── Canvas setup ──
    const canvasPanel = document.getElementById("anim-canvas-panel")!;
    const canvas = document.getElementById(
        "animation-canvas",
    ) as HTMLCanvasElement;
    const ctx = canvas.getContext("2d")!;
    const loader = document.getElementById("animation-loader")!;
    const loaderBar = document.getElementById("loader-bar")!;

    const DPR = window.devicePixelRatio || 1;
    canvas.width  = Math.round(canvasPanel.offsetWidth  * DPR);
    canvas.height = Math.round(canvasPanel.offsetHeight * DPR);

    // ── Frame storage ──
    const rawBuffers: (ArrayBuffer | null)[] = new Array(TOTAL_FRAMES).fill(
        null,
    );
    const bitmapCache = new Map<number, ImageBitmap>();
    const decoding = new Set<number>();

    let lastFrame = -1;
    let lastSection = -1;

    function framePath(i: number) {
        return `${FRAME_BASE}${String(i).padStart(4, "0")}${FRAME_SUFFIX}`;
    }

    // ── Fetch ──
    async function fetchFrame(i: number): Promise<void> {
        if (rawBuffers[i] !== null) return;
        try {
            rawBuffers[i] = await fetch(framePath(i)).then((r) =>
                r.arrayBuffer(),
            );
        } catch {
            rawBuffers[i] = new ArrayBuffer(0);
        }
    }

    // ── Decode ──
    async function ensureBitmap(i: number): Promise<void> {
        if (bitmapCache.has(i) || decoding.has(i)) return;
        const raw = rawBuffers[i];
        if (!raw || raw.byteLength === 0) return;
        decoding.add(i);
        try {
            const bmp = await createImageBitmap(
                new Blob([raw], { type: "image/webp" }),
            );
            bitmapCache.set(i, bmp);
        } finally {
            decoding.delete(i);
        }
    }

    // ── Sliding window ──
    function evict(center: number) {
        const lo = center - WINDOW_BEHIND - 2;
        const hi = center + WINDOW_AHEAD + 2;
        for (const [idx, bmp] of bitmapCache) {
            if (idx < lo || idx > hi) {
                bmp.close();
                bitmapCache.delete(idx);
            }
        }
    }

    function updateWindow(center: number) {
        evict(center);
        const lo = Math.max(0, center - WINDOW_BEHIND);
        const hi = Math.min(TOTAL_FRAMES - 1, center + WINDOW_AHEAD);
        for (let i = lo; i <= hi; i++) {
            if (rawBuffers[i]?.byteLength) ensureBitmap(i);
        }
    }

    // ── Draw (contain: preserve aspect ratio, centred) ──
    function drawFrame(index: number) {
        const bmp = bitmapCache.get(index);
        if (!bmp) return;

        const scale = Math.min(
            canvas.width / bmp.width,
            canvas.height / bmp.height,
        );
        const w = bmp.width * scale;
        const h = bmp.height * scale;
        const x = (canvas.width - w) / 2;
        const y = (canvas.height - h) / 2;

        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(bmp, x, y, w, h);
    }

    // ── Text slide-up transition ──
    function transitionText(fromIdx: number, toIdx: number, forward: boolean) {
        const exitY = forward ? "-100%" : "100%";
        const enterY = forward ? "100%" : "-100%";

        gsap.killTweensOf(slides[fromIdx]);
        gsap.killTweensOf(slides[toIdx]);

        gsap.to(slides[fromIdx], {
            y: exitY,
            duration: 0.55,
            ease: "power2.inOut",
        });
        gsap.fromTo(
            slides[toIdx],
            { y: enterY },
            { y: "0%", duration: 0.55, ease: "power2.inOut" },
        );
    }

    // ── ScrollTrigger ──
    function initScrollTrigger() {
        // Set initial text positions: slide 0 visible, rest below
        gsap.set(slides[0], { y: "0%" });
        gsap.set(slides.slice(1), { y: "100%" });

        drawFrame(0);

        ScrollTrigger.create({
            trigger: "#animation-section",
            start: "top top",
            end: () => "+=" + window.innerHeight * 6,
            pin: true,
            scrub: true,
            onUpdate(self) {
                const frame = Math.min(
                    TOTAL_FRAMES - 1,
                    Math.floor(self.progress * TOTAL_FRAMES),
                );

                if (frame !== lastFrame) {
                    lastFrame = frame;
                    drawFrame(frame);
                    updateWindow(frame);
                }

                // Find the last section whose `from` value is <= current frame
                let sectionIdx = 0;
                for (let s = 1; s < SECTION_STARTS.length; s++) {
                    if (frame >= SECTION_STARTS[s]) sectionIdx = s;
                }
                if (sectionIdx !== lastSection) {
                    if (lastSection !== -1) {
                        transitionText(
                            lastSection,
                            sectionIdx,
                            sectionIdx > lastSection,
                        );
                    }
                    lastSection = sectionIdx;
                }
            },
        });
    }

    // ── Background fetch pool ──
    async function fetchPool(indices: number[], concurrency: number) {
        let idx = 0;
        async function worker() {
            while (idx < indices.length) await fetchFrame(indices[idx++]);
        }
        await Promise.all(
            Array.from(
                { length: Math.min(concurrency, indices.length) },
                worker,
            ),
        );
    }

    // ── Boot ──
    async function boot() {
        // Skip animation setup on mobile
        if (window.innerWidth < 768) return;

        let done = 0;
        await Promise.allSettled(
            Array.from({ length: CRITICAL }, async (_, i) => {
                await fetchFrame(i);
                await ensureBitmap(i);
                loaderBar.style.width = `${(++done / CRITICAL) * 100}%`;
            }),
        );

        loader.style.opacity = "0";
        setTimeout(() => {
            loader.style.display = "none";
        }, 400);

        initScrollTrigger();

        const remaining = Array.from(
            { length: TOTAL_FRAMES - CRITICAL },
            (_, i) => i + CRITICAL,
        );
        await fetchPool(remaining, FETCH_CONCURRENCY);
    }

    boot();
</script>
