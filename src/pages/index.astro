---
import FrameAnimation from "../components/FrameAnimation.astro";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="dark" />
        <meta name="generator" content={Astro.generator} />
        <title>Mela</title>
        <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                background: #000;
                color: #fff;
                font-family:
                    system-ui,
                    -apple-system,
                    sans-serif;
                line-height: 1.5;
                overflow-x: hidden;
            }

            /* ScrollSmoother wrapper — must be position:fixed + overflow:hidden */
            #smooth-wrapper {
                overflow: hidden;
                position: fixed;
                height: 100%;
                width: 100%;
                top: 0;
                left: 0;
            }

            /* Top bar */
            .topbar {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 100;
                height: 64px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 2rem;
                background: transparent;
            }

            .topbar-logo {
                height: 28px;
                width: auto;
                flex-shrink: 0;
            }

            .topbar-nav {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                position: absolute;
                left: 50%;
                transform: translateX(-50%);
            }

            /* Shared pill button — liquid glass */
            .pill-btn {
                position: relative;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
                font-size: 0.875rem;
                font-weight: 600;
                letter-spacing: 0.02em;
                white-space: nowrap;
                border-radius: 100px;
                padding: 0.45rem 1.1rem;
                color: #fff;
                cursor: pointer;

                /* Glass surface: top reflection streak + orange tint */
                background:
                    linear-gradient(
                        170deg,
                        rgba(255, 255, 255, 0.28) 0%,
                        rgba(255, 220, 180, 0.08) 38%,
                        transparent 55%
                    ),
                    rgba(254, 127, 45, 0.18);

                /* Frosted glass blur */
                backdrop-filter: blur(18px) saturate(1.8) brightness(1.15);
                -webkit-backdrop-filter: blur(18px) saturate(1.8)
                    brightness(1.15);

                border: 1px solid transparent;
                background-clip: padding-box;

                /* Depth: bright top inner edge, soft orange bottom, outer glow */
                box-shadow:
                    inset 0 1.5px 0 rgba(255, 255, 255, 0.55),
                    inset 0 -1px 0 rgba(254, 127, 45, 0.25),
                    inset 1px 0 0 rgba(255, 255, 255, 0.12),
                    inset -1px 0 0 rgba(255, 255, 255, 0.12),
                    0 6px 28px rgba(254, 127, 45, 0.22),
                    0 1px 0 rgba(255, 255, 255, 0.06);

                overflow: hidden;
                transition:
                    box-shadow 0.2s ease,
                    background 0.2s ease;
            }

            .pill-btn:hover {
                background:
                    linear-gradient(
                        170deg,
                        rgba(255, 255, 255, 0.38) 0%,
                        rgba(255, 220, 180, 0.12) 38%,
                        transparent 55%
                    ),
                    rgba(88.6, 34.5, 13.3);
                box-shadow:
                    inset 0 1.5px 0 rgba(255, 255, 255, 0.65),
                    inset 0 -1px 0 rgba(254, 127, 45, 0.3),
                    inset 1px 0 0 rgba(255, 255, 255, 0.18),
                    inset -1px 0 0 rgba(255, 255, 255, 0.18),
                    0 8px 36px rgba(254, 127, 45, 0.35),
                    0 1px 0 rgba(255, 255, 255, 0.08);
            }

            /* Gradient glass rim — bright at top/corners, orange at bottom */
            .pill-btn::before {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: 100px;
                padding: 1px;
                background: linear-gradient(
                    145deg,
                    rgba(255, 255, 255, 0.85) 0%,
                    rgba(255, 210, 160, 0.5) 18%,
                    rgba(254, 127, 45, 0.15) 45%,
                    rgba(254, 127, 45, 0.15) 55%,
                    rgba(255, 190, 130, 0.4) 80%,
                    rgba(255, 255, 255, 0.6) 100%
                );
                -webkit-mask:
                    linear-gradient(#fff 0 0) content-box,
                    linear-gradient(#fff 0 0);
                -webkit-mask-composite: xor;
                mask-composite: exclude;
                pointer-events: none;
            }

            /* Cursor proximity radial glow */
            .pill-btn::after {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: 100px;
                background: radial-gradient(
                    circle 70px at var(--rx, 50%) var(--ry, 50%),
                    rgba(255, 210, 160, 0.5) 0%,
                    transparent 100%
                );
                opacity: var(--glow, 0);
                transition: opacity 0.15s ease;
                pointer-events: none;
            }

            .topbar-cta {
                flex-shrink: 0;
            }

            /* Hero */
            .hero-scroll-container {
                height: 250vh;
                position: relative;
            }

            .hero {
                position: sticky;
                top: 0;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                background:
                    radial-gradient(
                        ellipse 80% 60% at 50% 60%,
                        rgba(254, 127, 45, 0.45) 0%,
                        transparent 70%
                    ),
                    #000;
            }

            .hero-title {
                position: absolute;
                inset: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: clamp(4rem, 13vw, 12rem);
                font-weight: 800;
                letter-spacing: -0.04em;
                line-height: 1;
                text-align: center;
                color: #ffffff;
                /* Behind image (z-index 1), above background (z-index 0) */
                z-index: 1;
                padding: 0 2rem;
                pointer-events: none;
                user-select: none;
            }

            .hero-figure {
                width: 70%;
                max-width: 900px;
                height: 100%;
                object-fit: contain;
                object-position: center bottom;
                will-change: transform;
            }

            .hero-overlay {
                position: absolute;
                inset: 0;
                background: #000000;
                opacity: 0;
                pointer-events: none;
            }

            /* Placeholder sections */
            .section {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 4rem 2rem;
                border-top: 1px solid rgba(255, 255, 255, 0.06);
            }

            .section-inner {
                max-width: 720px;
                width: 100%;
                text-align: center;
            }

            .section-inner h2 {
                font-size: clamp(1.5rem, 4vw, 2.5rem);
                font-weight: 600;
                letter-spacing: -0.01em;
            }

            .section-inner p {
                margin-top: 1rem;
                color: rgba(255, 255, 255, 0.45);
                font-size: 1.0625rem;
            }
        </style>
    </head>
    <body>
        <!-- Top bar sits outside smooth-wrapper so it's unaffected by the scroll offset -->
        <header class="topbar">
            <img src="/TFS_Logo.svg" alt="TFS Logo" class="topbar-logo" />
            <nav class="topbar-nav">
                <a href="#" class="pill-btn">Features</a>
                <a href="#" class="pill-btn">About</a>
                <a href="#" class="pill-btn">Contact</a>
            </nav>
            <a href="#" class="pill-btn topbar-cta">Get Started</a>
        </header>

        <!-- ScrollSmoother requires this exact wrapper > content structure -->
        <div id="smooth-wrapper">
            <div id="smooth-content">
                <!-- Hero -->
                <div class="hero-scroll-container">
                    <section class="hero" id="hero">
                        <div class="hero-title">The Future<br />Studio</div>
                        <img
                            src="/heroImage.png"
                            alt=""
                            class="hero-figure"
                            id="hero-figure"
                            style="position: relative; z-index: 2;"
                        />
                        <div
                            class="hero-overlay"
                            id="hero-overlay"
                            style="z-index: 3;"
                        >
                        </div>
                    </section>
                </div>

                <!-- Scroll-controlled frame animation -->
                <FrameAnimation />
            </div>
        </div>

        <script>
            // Cursor proximity glow for pill buttons
            const pillBtns =
                document.querySelectorAll<HTMLElement>(".pill-btn");
            const PROXIMITY = 120;

            window.addEventListener("mousemove", (e) => {
                pillBtns.forEach((btn) => {
                    const rect = btn.getBoundingClientRect();
                    const cx = rect.left + rect.width / 2;
                    const cy = rect.top + rect.height / 2;
                    const dx = e.clientX - cx;
                    const dy = e.clientY - cy;
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    const rx = ((e.clientX - rect.left) / rect.width) * 100;
                    const ry = ((e.clientY - rect.top) / rect.height) * 100;

                    const glow = Math.max(0, 1 - dist / PROXIMITY);
                    btn.style.setProperty("--rx", `${rx}%`);
                    btn.style.setProperty("--ry", `${ry}%`);
                    btn.style.setProperty("--glow", `${glow}`);
                });
            });
        </script>

        <script>
            import { gsap } from "gsap";
            import { ScrollTrigger } from "gsap/ScrollTrigger";
            import { ScrollSmoother } from "gsap/ScrollSmoother";

            gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

            // ScrollSmoother MUST be created before any ScrollTrigger.create() calls
            ScrollSmoother.create({
                wrapper: "#smooth-wrapper",
                content: "#smooth-content",
                smooth: 1,
                effects: true,
                smoothTouch: 0.1,
            });

            const figure = document.getElementById(
                "hero-figure",
            ) as HTMLImageElement;
            const overlay = document.getElementById("hero-overlay");

            // ── Zoom focal point ──────────────────────────────────────────
            // Values are 0–1, relative to the image's own dimensions.
            // 0 = left / top edge,  1 = right / bottom edge,  0.5 = centre.
            const ZOOM_FOCAL_X = 0.5; // horizontal
            const ZOOM_FOCAL_Y = 0.15; // vertical
            // ─────────────────────────────────────────────────────────────

            function updateTransformOrigin() {
                const elW = figure.offsetWidth;
                const elH = figure.offsetHeight;
                const natW = figure.naturalWidth;
                const natH = figure.naturalHeight;
                if (!natW || !natH) return;

                // Replicate object-fit:contain + object-position:center bottom
                const scale = Math.min(elW / natW, elH / natH);
                const imgW = natW * scale;
                const imgH = natH * scale;
                const xOff = (elW - imgW) / 2; // centred horizontally
                const yOff = elH - imgH; // bottom-aligned

                // Map focal fraction → pixel inside element → percentage
                const originX = ((xOff + imgW * ZOOM_FOCAL_X) / elW) * 100;
                const originY = ((yOff + imgH * ZOOM_FOCAL_Y) / elH) * 100;

                gsap.set(figure, {
                    transformOrigin: `${originX}% ${originY}%`,
                });
            }

            if (figure.complete) {
                updateTransformOrigin();
            } else {
                figure.addEventListener("load", updateTransformOrigin);
            }
            window.addEventListener("resize", updateTransformOrigin);

            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: ".hero-scroll-container",
                    start: "top top",
                    end: "bottom bottom",
                    scrub: true,
                },
            });

            tl.to(figure, { scale: 12, ease: "none" }, 0).to(
                overlay,
                { opacity: 1, ease: "none" },
                0,
            );
        </script>
    </body>
</html>
